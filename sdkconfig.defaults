CONFIG_IDF_TARGET="esp32c6"

# ── libsodium ───────────────────────────────────────────────
CONFIG_LIBSODIUM_USE_MBEDTLS_SHA=y

# ── Bluetooth (NimBLE for Matter commissioning) ─────────────
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_EXT_ADV=n
CONFIG_BT_NIMBLE_HCI_EVT_BUF_SIZE=70
CONFIG_BT_NIMBLE_ENABLE_CONN_REATTEMPT=n
CONFIG_USE_BLE_ONLY_FOR_COMMISSIONING=y

# ── FreeRTOS ────────────────────────────────────────────────
CONFIG_FREERTOS_ENABLE_BACKWARD_COMPATIBILITY=y
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_CANARY=y

# ── Flash / serial ──────────────────────────────────────────
CONFIG_ESPTOOLPY_BAUD_921600B=y
CONFIG_ESPTOOLPY_BAUD=921600
CONFIG_ESPTOOLPY_COMPRESSED=y
CONFIG_ESPTOOLPY_MONITOR_BAUD_115200B=y
CONFIG_ESPTOOLPY_MONITOR_BAUD=115200
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# ── lwIP (IPv6 forwarding required for border routing) ─────
CONFIG_LWIP_IPV4=y
CONFIG_LWIP_IPV6_AUTOCONFIG=y
CONFIG_LWIP_IPV6_FORWARD=y
CONFIG_LWIP_IPV6_NUM_ADDRESSES=12
CONFIG_LWIP_MULTICAST_PING=y
CONFIG_LWIP_NETIF_STATUS_CALLBACK=y
CONFIG_LWIP_HOOK_IP6_ROUTE_DEFAULT=y
CONFIG_LWIP_HOOK_ND6_GET_GW_DEFAULT=y
CONFIG_LWIP_HOOK_IP6_INPUT_CUSTOM=y
CONFIG_LWIP_HOOK_IP6_SELECT_SRC_ADDR_CUSTOM=y

# ── Partition table ─────────────────────────────────────────
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0xC000

# ── Matter / CHIP ───────────────────────────────────────────
CONFIG_ENABLE_CHIP_SHELL=y
# TBR needs platform mDNS for SRP/mDNS proxy — not the minimal CHIP mDNS
CONFIG_USE_MINIMAL_MDNS=n
# Disable CHIP route hooks — OpenThread BR provides its own
CONFIG_ENABLE_ROUTE_HOOK=n
CONFIG_ENABLE_EXTENDED_DISCOVERY=y
# OTA disabled — binary exceeds dual-OTA capacity on 4 MB flash
CONFIG_ENABLE_OTA_REQUESTOR=n
CONFIG_ESP_MATTER_NVS_USE_COMPACT_ATTR_STORAGE=y
CONFIG_CHIP_ENABLE_BDX_LOG_TRANSFER=y

# ── mbedTLS (DTLS required by OpenThread secure transport) ──
CONFIG_MBEDTLS_HKDF_C=y
CONFIG_MBEDTLS_CMAC_C=y
CONFIG_MBEDTLS_SSL_PROTO_DTLS=y
CONFIG_MBEDTLS_KEY_EXCHANGE_ECJPAKE=y
CONFIG_MBEDTLS_ECJPAKE_C=y

# ── mDNS ────────────────────────────────────────────────────
CONFIG_MDNS_MULTIPLE_INSTANCE=y

# ── WiFi (station — uplink to IP network) ──────────────────
CONFIG_ENABLE_WIFI_STATION=y
CONFIG_ENABLE_WIFI_AP=n
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n
CONFIG_DEFAULT_WIFI_SSID="Boy1212  2.4G"
CONFIG_DEFAULT_WIFI_PASSWORD="0620380499"
CONFIG_WIFI_STATION_RECONNECT_INTERVAL=1000
CONFIG_MAX_SCAN_NETWORKS_RESULTS=3000
CONFIG_WIFI_SCAN_COMPLETION_TIMEOUT=10000

# ── IEEE 802.15.4 radio (Thread PHY on ESP32-C6) ───────────
CONFIG_IEEE802154_ENABLED=y

# ── OpenThread ──────────────────────────────────────────────
CONFIG_OPENTHREAD_ENABLED=y
CONFIG_OPENTHREAD_BORDER_ROUTER=y
CONFIG_OPENTHREAD_SRP_SERVER=y
CONFIG_OPENTHREAD_SRP_CLIENT=n
CONFIG_OPENTHREAD_DNS_CLIENT=n
CONFIG_OPENTHREAD_DNS64=y
CONFIG_OPENTHREAD_LOG_LEVEL_DYNAMIC=n
CONFIG_OPENTHREAD_LOG_LEVEL_NOTE=y
# TBR endpoint handles Thread commissioning — disable the automatic driver
# to avoid duplicate NetworkCommissioningCluster registration (abort)
CONFIG_THREAD_NETWORK_COMMISSIONING_DRIVER=n

# ── Thread Border Router ────────────────────────────────────
CONFIG_ENABLE_THREAD_BORDER_ROUTER=y
CONFIG_OPENTHREAD_BR_AUTO_START=y

# ── Coexistence (WiFi + 802.15.4 share RF front-end) ───────
CONFIG_ESP_COEX_SW_COEXIST_ENABLE=y

# ── Button / BSP ────────────────────────────────────────────
CONFIG_BUTTON_PERIOD_TIME_MS=20
CONFIG_BUTTON_LONG_PRESS_TIME_MS=5000
CONFIG_BSP_BUTTONS_NUM=1
CONFIG_BSP_BUTTON_1_TYPE_GPIO=y
CONFIG_BSP_BUTTON_1_GPIO=0
CONFIG_BSP_BUTTON_1_LEVEL=0
CONFIG_BSP_LEDS_NUM=0

# ── Security ────────────────────────────────────────────────
CONFIG_ESP_SECURE_CERT_DS_PERIPHERAL=n

# ── Diagnostics / core dump ─────────────────────────────────
CONFIG_ESP32_ENABLE_COREDUMP_TO_FLASH=y
CONFIG_ESP32_COREDUMP_DATA_FORMAT_ELF=y

# ── Stack sizes (Swift + Matter + OpenThread need room) ─────
CONFIG_ESP_MAIN_TASK_STACK_SIZE=24576
CONFIG_CHIP_TASK_STACK_SIZE=24576
CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=12288
CONFIG_ESP_TIMER_TASK_STACK_SIZE=8192
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=8192
CONFIG_OPENTHREAD_TASK_STACK_SIZE=8192

# Disable OTA Clusters (No OTA support on 4MB flash)
CONFIG_SUPPORT_OTA_SOFTWARE_UPDATE_PROVIDER_CLUSTER=n
CONFIG_SUPPORT_OTA_SOFTWARE_UPDATE_REQUESTOR_CLUSTER=n
CONFIG_BT_NIMBLE_TASK_STACK_SIZE=12288
